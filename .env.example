# ─── Recio environment (copy to .env and fill in) ───────────────────────────
# Root .env is read by the server. Never commit the real .env.
# In production, inject these as real env vars (Render/Railway/Fly/Docker) instead.

# ── Server ──
NODE_ENV=development
PORT=4000
# The web app origin (used for CORS + OAuth redirects back to the app).
# Production: e.g. https://recio.app
WEB_ORIGIN=http://localhost:5173
# Public origin of THIS API server. Used to build absolute media-stream URLs that
# the browser loads directly (e.g. Drive playback proxy). Production: https://api.recio.app
API_PUBLIC_URL=http://localhost:4000
# TESTING ONLY: grant every account full (Business) entitlements so Pro/Business
# features can be exercised without paying. MUST be false (or unset) in production.
UNLOCK_ALL_FEATURES=false

# ── Database ──
# Local docker-compose: postgresql://flowcap:flowcap@localhost:5432/flowcap?schema=public
# Production: your managed Postgres URL (run `prisma migrate deploy` against it).
DATABASE_URL=postgresql://flowcap:flowcap@localhost:5432/flowcap?schema=public

# ── JWT ──  (generate: `openssl rand -hex 32`)
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_a_different_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Token encryption (AES-256-GCM for stored Drive/Dropbox tokens) ──
# MUST be exactly 32 bytes, hex-encoded (64 hex chars): `openssl rand -hex 32`
TOKEN_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

# ── Google OAuth (Google Cloud Console → Web application client) ──
GOOGLE_CLIENT_ID=replace_with_your_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_your_web_client_secret
# Production: https://api.recio.app/storage/drive/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/storage/drive/callback

# ── Dropbox OAuth (optional — dropbox.com/developers → create an app) ──
# Leave blank to disable the Dropbox storage option.
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_OAUTH_REDIRECT_URI=http://localhost:4000/storage/dropbox/callback

# ── Recio object storage (Supabase Storage) ──
# Supabase → Settings → API. Use the SECRET key (sb_secret_… or service_role JWT),
# NOT the publishable/anon key. Create a private Storage bucket named below.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key
SUPABASE_STORAGE_BUCKET=recio-media

# ── Signed URL TTL (seconds) for playback of Recio-stored media ──
SIGNED_URL_TTL=3600

# ─── Web app build-time vars (set in web/.env or your host's env) ───────────
# VITE_API_BASE_URL=https://api.recio.app
# VITE_GOOGLE_CLIENT_ID=...        # GIS "Sign in with Google" on the web
#
# ─── Extension build-time vars (extension/.env) ─────────────────────────────
# VITE_API_BASE_URL=https://api.recio.app
# VITE_WEB_BASE_URL=https://recio.app
# VITE_GOOGLE_CLIENT_ID=...
# VITE_DROPBOX_CLIENT_ID=...
