// FlowCap data model. See the architecture doc for rationale.
// Conventions: soft delete via `deletedAt` on media; Drive OAuth tokens stored
// only as AES-256-GCM ciphertext (never plaintext); cursor pagination via the
// (userId, createdAt, id) indexes on media tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum StorageProvider {
  DRIVE
  DROPBOX
  FLOWCAP
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ResourceType {
  RECORDING
  SCREENSHOT
}

enum SharePermission {
  VIEW
  COMMENT
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  avatar       String?
  passwordHash String? // null for Google-only accounts
  googleId     String? @unique
  plan         Plan    @default(FREE) // denormalized entitlement; billing truth lives on Subscription
  stripeCustomerId String? @unique

  // Pro "custom branding" — applied to this user's public share pages (gated by the
  // customBranding entitlement at read/write time). null = default Recio branding.
  brandName    String?
  brandLogoUrl String?
  ctaLabel     String?
  ctaUrl       String?

  storageConnections StorageConnection[]
  recordings         Recording[]
  screenshots        Screenshot[]
  shares             Share[]
  subscription       Subscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * The billing source of truth, synced from Stripe webhooks. `User.plan` is the
 * fast-read denormalization of this row's `plan` (flipped only by webhook handlers).
 */
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeSubscriptionId String    @unique
  stripePriceId        String
  plan                 Plan
  status               SubStatus
  seats                Int       @default(1)
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Idempotency guard: Stripe redelivers events, so we record processed ids. */
model WebhookEvent {
  id          String   @id // Stripe event id
  processedAt DateTime @default(now())
}

/** Per-period usage meters for the metered add-ons (reset on invoice.paid). */
model UsageCounter {
  id          String   @id @default(cuid())
  userId      String
  periodStart DateTime
  aiMinutes   Int      @default(0) // transcription minutes consumed
  proxyBytes  BigInt   @default(0) // bytes streamed via the media.ts proxy
  hostedBytes BigInt   @default(0) // bytes in Recio-hosted (FLOWCAP) storage

  @@unique([userId, periodStart])
  @@index([userId])
}

model StorageConnection {
  id       String          @id @default(cuid())
  userId   String
  provider StorageProvider

  // AES-256-GCM ciphertext (iv:authTag:data hex). Null for the FLOWCAP provider.
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  driveEmail   String?
  defaultFolderId String?

  isActive  Boolean @default(true)
  // Exactly one connection per user should be the default upload destination.
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model Recording {
  id          String @id @default(cuid())
  userId      String
  title       String
  description String?

  duration Int    // seconds
  size     BigInt // bytes
  mimeType String // video/webm | video/mp4

  // Non-destructive trim (seconds). When set, players clamp playback to this range;
  // the underlying file in the user's cloud is left untouched. null = no trim.
  trimStartSec Float?
  trimEndSec   Float?

  storageProvider StorageProvider
  storageFileId   String // Drive file ID or FlowCap S3 object key
  thumbnailUrl    String?

  shareToken String  @unique @default(cuid())
  isPublic   Boolean @default(false)
  viewCount  Int     @default(0)

  // When set, this lives in a workspace's shared team library (Business). null = personal.
  workspaceId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, createdAt, id])
  @@index([shareToken])
  @@index([workspaceId, createdAt, id])
}

model Screenshot {
  id     String @id @default(cuid())
  userId String
  title  String

  size     BigInt // bytes
  mimeType String // image/png | image/jpeg

  storageProvider StorageProvider
  storageFileId   String
  thumbnailUrl    String?

  shareToken String  @unique @default(cuid())
  isPublic   Boolean @default(false)
  viewCount  Int     @default(0)

  // When set, this lives in a workspace's shared team library (Business). null = personal.
  workspaceId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, createdAt, id])
  @@index([shareToken])
  @@index([workspaceId, createdAt, id])
}

model Share {
  id              String          @id @default(cuid())
  resourceType    ResourceType
  resourceId      String
  createdByUserId String
  token           String          @unique @default(cuid())
  permission      SharePermission @default(VIEW)
  expiresAt       DateTime?

  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([createdByUserId])
}

// Aggregate reaction counts per media item + emoji. Polymorphic (resourceId points
// at a Recording or Screenshot), so no FK — kept loose on purpose.
model Reaction {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  emoji        String
  count        Int          @default(0)
  updatedAt    DateTime     @updatedAt

  @@unique([resourceId, emoji])
  @@index([resourceId])
}

// One row per view session (page-load) of a media item. `watchedPct` is the max
// progress reached, updated as the viewer watches. Powers the engagement analytics
// (total/unique views, avg watch-through, drop-off). Polymorphic resourceId (no FK).
model ViewEvent {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  viewerId     String // anonymous, persisted in the viewer's localStorage
  sessionId    String       @unique // one per page-load; the upsert key
  watchedPct   Int          @default(0) // 0..100, max reached
  createdAt    DateTime     @default(now())

  @@index([resourceId, createdAt])
}

// Comments on a media item. Polymorphic resourceId; authorUserId is set when an
// authenticated user posts, otherwise it's a guest with just a display name.
model Comment {
  id           String       @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  authorUserId String?
  authorName   String
  body         String
  timestampSec Int?
  createdAt    DateTime     @default(now())

  @@index([resourceId, createdAt])
}

// ── Team workspaces (Business) ────────────────────────────────────────────────
// A shared space with members and a shared media library. `Membership.userId` /
// `Invite` reference users loosely (no FK) to keep churn low; the workspace owns its
// rows (cascade). Media gains an optional `workspaceId` to land in the team library.
model Workspace {
  id      String @id @default(cuid())
  name    String
  ownerId String

  members Membership[]
  invites Invite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Membership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Invite {
  id              String        @id @default(cuid())
  workspaceId     String
  email           String
  role            WorkspaceRole @default(MEMBER)
  token           String        @unique @default(cuid())
  invitedByUserId String
  acceptedAt      DateTime?
  expiresAt       DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([email])
}
