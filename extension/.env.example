# Extension build-time config (copy to .env). Vite only exposes VITE_-prefixed vars.

# FlowCap backend base URL.
VITE_API_BASE_URL=http://localhost:4000

# Google OAuth *Web* client id (used with chrome.identity.launchWebAuthFlow).
# Add the extension's redirect URL — chrome.identity.getRedirectURL() prints
# https://<extension-id>.chromiumapp.org/ — to this client's authorized redirect URIs.
VITE_GOOGLE_CLIENT_ID=replace_with_your_web_client_id.apps.googleusercontent.com
