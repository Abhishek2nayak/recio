# ─── FlowCap environment (copy to .env and fill in) ─────────────────────────
# Root .env is shared by the server. Never commit the real .env.

# ── Server ──
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173

# ── Database (matches docker-compose.yml) ──
DATABASE_URL=postgresql://flowcap:flowcap@localhost:5432/flowcap?schema=public

# ── JWT ──
# Generate strong values: `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_a_different_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Token encryption (AES-256-GCM for stored Drive tokens) ──
# MUST be exactly 32 bytes, hex-encoded (64 hex chars): `openssl rand -hex 32`
TOKEN_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

# ── Google OAuth (user must create these in Google Cloud Console) ──
# Web client (for the web app's "Sign in with Google" + Drive connect):
GOOGLE_CLIENT_ID=replace_with_your_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_your_web_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/storage/drive/callback

# ── FlowCap object storage (Supabase Storage) ──
# From your Supabase project: Settings → API. The service-role key is SECRET and
# stays server-side only. Create a (private) Storage bucket named below.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key
SUPABASE_STORAGE_BUCKET=flowcap-media

# ── Signed URL TTL (seconds) for playback of FlowCap-stored media ──
SIGNED_URL_TTL=3600
